      <data key="d4">['customer_id', 'customer_name', 'count_lifetime_orders', 'first_ordered_at', 'last_ordered_at', 'lifetime_spend_pretax', 'lifetime_tax_paid', 'lifetime_spend', 'customer_type']</data>
