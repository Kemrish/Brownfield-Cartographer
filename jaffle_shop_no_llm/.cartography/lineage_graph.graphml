    <node id="sql_C__Users_ADMINI~1_AppData_Local_Temp_cartographer_tvkcevga_models_marts_orders.sql">
      <data key="d0">transformation</data>
      <data key="d14">sql:C:/Users/ADMINI~1/AppData/Local/Temp/cartographer_tvkcevga/models/marts/orders.sql</data>
      <data key="d15">['stg_orders', 'order_items']</data>
      <data key="d16">['orders']</data>
