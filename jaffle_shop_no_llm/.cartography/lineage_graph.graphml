    <node id="sql_C__Users_ADMINI~1_AppData_Local_Temp_cartographer_tvkcevga_models_marts_customers.sql">
      <data key="d0">transformation</data>
      <data key="d14">sql:C:/Users/ADMINI~1/AppData/Local/Temp/cartographer_tvkcevga/models/marts/customers.sql</data>
      <data key="d15">['stg_customers', 'orders']</data>
      <data key="d16">['customers']</data>
